#!/usr/bin/env python3
"""PII guard (v5 §2): block a commit whose STAGED changes contain personal data
or forbidden data paths. Installed via: git config core.hooksPath githooks

Blocks:
  - real-looking emails (allowlist: synthetic spec/test domains)
  - Korean phone numbers (mobile 010-... and full landline forms)
  - staging anything under the data corpora / spreadsheets, even with `git add -f`

False positive? Fix the content (mask it) — or, for a genuinely synthetic value,
add its domain to ALLOWED_EMAIL_DOMAINS below. `--no-verify` exists but the
default is: PII never lands in a commit.

Known accepted limitations (documented, not bugs):
  - obfuscated ("x [at] y dot com") or line-split emails are not detected;
    the guard stops verbatim single-line emails only.
  - the landline phone shape can false-positive on ISBN-like numerics
    (0X-XXXX-XXXX shaped); mask the value or use --no-verify for genuine non-PII.
"""
import re
import subprocess
import sys

# Non-ASCII (e.g. Korean) paths MUST NOT be octal-quoted by git, or the path
# rules and the per-file content scan silently miss them (verified bypass).
GIT = ["git", "-c", "core.quotePath=false"]

ALLOWED_EMAIL_DOMAINS = {
    "example.com", "example.org",
    "univ.ac.kr",            # the spec documents' synthetic examples
    "anthropic.com",         # commit trailer
}

FORBIDDEN_PATHS = [
    re.compile(r"^data/(records|normalized|candidates|splits|raw|canonical|augmented|gold)/"),
    re.compile(r"\.xlsx?$", re.IGNORECASE),
    re.compile(r"^실라버스"),
]

EMAIL = re.compile(r"[A-Za-z0-9._%+-]+@([A-Za-z0-9.-]+\.[A-Za-z]{2,})")
# full Korean phone numbers only (truncated examples like 02-2123-456 don't match)
PHONE = re.compile(r"(?<!\d)(?:010[-.\s]?\d{4}[-.\s]?\d{4}|0\d{1,2}[-.\s]\d{3,4}[-.\s]\d{4})(?!\d)")


def staged_files() -> list[str]:
    # -z: NUL-separated raw paths — immune to quoting/newline mangling.
    out = subprocess.run(GIT + ["diff", "--cached", "--name-only", "-z", "--diff-filter=ACMR"],
                         capture_output=True, text=True).stdout
    return [p for p in out.split("\0") if p.strip()]


def staged_added_lines(path: str) -> list[str]:
    out = subprocess.run(GIT + ["diff", "--cached", "--unified=0", "--", path],
                         capture_output=True, text=True).stdout
    return [l[1:] for l in out.splitlines() if l.startswith("+") and not l.startswith("+++")]


def main() -> int:
    problems: list[str] = []
    for path in staged_files():
        for pat in FORBIDDEN_PATHS:
            if pat.search(path):
                problems.append(f"forbidden data path staged: {path}")
                break
        else:
            for line in staged_added_lines(path):
                for m in EMAIL.finditer(line):
                    if m.group(1).lower() not in ALLOWED_EMAIL_DOMAINS:
                        problems.append(f"email in {path}: {m.group(0)}")
                for m in PHONE.finditer(line):
                    problems.append(f"phone number in {path}: {m.group(0)}")

    if problems:
        print("PII GUARD — commit blocked (v5 §2):", file=sys.stderr)
        for p in problems[:20]:
            print(f"  ✗ {p}", file=sys.stderr)
        print("Mask the value, use a synthetic one, or unstage the file.", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
